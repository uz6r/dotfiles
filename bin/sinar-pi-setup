#!/usr/bin/env bash
#
# sinar-pi-setup - Build + create config(s) + package sinarclient
# Stops at packaging; run "make sync HOST=<hostname>" manually when Pi is ready.
#
# Usage:
#   Interactive:   sinar-pi-setup
#   Non-interactive: sinar-pi-setup config1.toml [config2.toml ...]
#   Flags:         --no-build  --dry-run
#
if [[ -n "$SUDO_USER" ]]; then
  ACTUAL_HOME="$(eval echo "~$SUDO_USER")"
else
  ACTUAL_HOME="$HOME"
fi
SINAR_DIR="${SINAR_DIR:-${COURTSITE_DIR:-$ACTUAL_HOME/Courtsite}/enjin/sinar-client}"
cd "$SINAR_DIR" || exit 1

SKIP_BUILD=false
DRY_RUN=false
SKIP_GIT=false

while [[ $# -gt 0 ]]; do
  case "$1" in
    --no-build)  SKIP_BUILD=true; shift ;;
    --dry-run)   DRY_RUN=true; shift ;;
    --no-git)    SKIP_GIT=true; shift ;;
    -h|--help)
      echo "Usage: sinar-pi-setup [--no-build] [--dry-run] [--no-git] [config1.toml config2.toml ...]"
      exit 0
      ;;
    *) break ;;
  esac
done

run() {
  if $DRY_RUN; then
    echo "  [DRY-RUN] $*"
  else
    "$@"
  fi
}

prompt() {
  local var="$1" msg="$2" default="${3:-}"
  if [[ -n "$default" ]]; then
    read -r -p "${msg} [$default]: " "$var"
    eval "[[ -z \"\$$var\" ]] && $var=\"$default\""
  else
    read -r -p "${msg}: " "$var"
  fi
}

do_build() {
  echo "==> Building pi-client and sinar-client"
  run make
}

# Create config with custom BoardID, ToggleTime etc
create_config() {
  local centre_name tenant_id board_id toggle_time fallback_count frequency brand
  centre_name="$1"
  tenant_id="$2"
  board_id="${3:-1}"
  toggle_time="${4:-5s}"
  fallback_count="${5:-0}"
  frequency="${6:-10s}"
  brand="${7:-weiba}"

  centre_name="${centre_name%.toml}"
  local config_path="configs/${centre_name}.toml"
  local content="TenantID = \"${tenant_id}\"
BoardID = ${board_id}
FallbackCount = ${fallback_count}
Frequency = \"${frequency}\"
ToggleTime = \"${toggle_time}\"
Brand = \"${brand}\"
"
  if $DRY_RUN; then
    echo "  [DRY-RUN] write $config_path"
  else
    echo "$content" > "$config_path"
  fi
  echo "$config_path"
}

do_pkger() {
  local sinarcfg="$1" is_multi="$2"
  echo "==> Packaging sinarclient.tar.gz"
  if [[ "$is_multi" == "1" ]]; then
    run make pkger-multi SINARCFG="$sinarcfg"
  else
    run make pkger SINARCFG="$sinarcfg"
  fi
}

git_prepare() {
  local branch_name="$1"
  echo "==> Preparing git: checkout master + pull + new branch"
  run git checkout master
  run git pull origin master
  run git checkout -b "$branch_name"
}

git_commit_and_pr() {
  local branch_name="$1" is_multi="$2" num_configs="$3"
  shift 3
  local configs=("$@")

  echo "==> Committing and creating PR"
  run git add configs/

  local commit_msg="Add pi configs for $num_configs setup(s)"
  if [[ "$is_multi" == "1" ]]; then
    commit_msg="Add pi configs for multi-pi setup ($num_configs configs)"
  fi
  run git commit -m "$commit_msg"

  local centre_names=""
  for cfg in "${configs[@]}"; do
    local cfg_file=$(basename "$cfg")
    centre_names+="${cfg_file%.toml} "
  done
  centre_names=$(echo "$centre_names" | xargs)

  local base_centre
  base_centre=$(echo "$centre_names" | awk '{print $1}' | sed 's/-[0-9]*$//')

  local pr_title pr_body
  if [[ "$is_multi" == "1" ]]; then
    pr_title="Sinar - Add ${base_centre} Multi-pi Setup Config (${num_configs} boards)"
  else
    pr_title="Sinar - Add ${centre_names} Pi Setup Config"
  fi

  local pr_body="## Setup Details

- **Type:** $([[ "$is_multi" == "1" ]] && echo "Multi-pi" || echo "Single-pi")
- **Number of Pi(s):** $num_configs
- **Branch:** $branch_name

## Configs

"
  for cfg in "${configs[@]}"; do
    local cfg_file=$(basename "$cfg")
    if [[ -f "configs/$cfg_file" ]]; then
      local tenant_id board_id toggle_time fallback_count frequency brand
      tenant_id=$(grep -oP 'TenantID = "\K[^"]+' "configs/$cfg_file")
      board_id=$(grep -oP 'BoardID = \K\d+' "configs/$cfg_file")
      toggle_time=$(grep -oP 'ToggleTime = "\K[^"]+' "configs/$cfg_file")
      fallback_count=$(grep -oP 'FallbackCount = \K\d+' "configs/$cfg_file")
      frequency=$(grep -oP 'Frequency = "\K[^"]+' "configs/$cfg_file")
      brand=$(grep -oP 'Brand = "\K[^"]+' "configs/$cfg_file")
      pr_body+="### $cfg_file
- TenantID: $tenant_id
- BoardID: $board_id
- ToggleTime: $toggle_time
- FallbackCount: $fallback_count
- Frequency: $frequency
- Brand: $brand

"
    fi
  done

  pr_body+="---
Generated by sinar-pi-setup"

  run git push -u origin "$branch_name"
  run gh pr create --title "$pr_title" --body "$pr_body"
}

main() {
  local CONFIG_PATHS CONFIG_PATH IS_MULTI=0

  if [[ $# -ge 1 ]]; then
    # Non-interactive: config path(s) as args
    CONFIG_PATHS=("$@")
    [[ ${#CONFIG_PATHS[@]} -ge 2 ]] && IS_MULTI=1
    [[ ${#CONFIG_PATHS[@]} -eq 1 ]] && CONFIG_PATH="${CONFIG_PATHS[0]}" || CONFIG_PATH="${CONFIG_PATHS[*]}"
    echo "Config(s): $CONFIG_PATH"
  else
    # Interactive
    echo "=== Sinar Pi Setup ==="
    echo "Package: (1) single  (2) multi"
    read -r -p "Choice: " pkg_choice
    [[ "$pkg_choice" == "2" ]] && IS_MULTI=1

    if [[ "$IS_MULTI" == "1" ]]; then
      local count configs=()
      prompt count "Number of configs" "2"
      for ((i=1; i<=count; i++)); do
        echo "--- Config $i ---"
        local centre_name tenant_id board_id toggle_time fallback_count frequency brand
        prompt centre_name "Centre name (e.g. OncidiumHallKotaKemuning)"
        prompt tenant_id "Tenant ID (from Metabase)"
        prompt board_id "BoardID" "1"
        prompt toggle_time "ToggleTime" "5s"
        prompt fallback_count "FallbackCount" "0"
        prompt frequency "Frequency" "10s"
        prompt brand "Brand" "weiba"
        configs+=("$(create_config "$centre_name" "$tenant_id" "$board_id" "$toggle_time" "$fallback_count" "$frequency" "$brand")")
      done
      CONFIG_PATH="${configs[*]}"
    else
      local centre_name tenant_id board_id toggle_time fallback_count frequency brand
      prompt centre_name "Centre name (e.g. OncidiumHallKotaKemuning)"
      prompt tenant_id "Tenant ID (from Metabase)"
      prompt board_id "BoardID" "1"
      prompt toggle_time "ToggleTime" "5s"
      prompt fallback_count "FallbackCount" "0"
      prompt frequency "Frequency" "10s"
      prompt brand "Brand" "weiba"
      CONFIG_PATH=$(create_config "$centre_name" "$tenant_id" "$board_id" "$toggle_time" "$fallback_count" "$frequency" "$brand")
    fi
  fi

  CONFIG_PATH="$(echo "$CONFIG_PATH" | tr -d '\n\r')"

  local branch_name
  if [[ "$IS_MULTI" == "1" ]]; then
    branch_name="pi-setup-multi-$(date +%Y%m%d)"
  else
    branch_name="pi-setup-$(echo "$CONFIG_PATH" | cut -d'/' -f2 | cut -d'.' -f1)-$(date +%Y%m%d)"
  fi

  git_prepare "$branch_name"

  $SKIP_BUILD || do_build
  do_pkger "$CONFIG_PATH" "$IS_MULTI"

  local num_configs=${#CONFIG_PATHS[@]}
  [[ $num_configs -eq 0 ]] && num_configs=1

  if [[ "$SKIP_GIT" != "true" ]]; then
    git_commit_and_pr "$branch_name" "$IS_MULTI" "$num_configs" "${CONFIG_PATHS[@]}"
  else
    echo "==> Skipping git (--no-git)"
    echo "    Branch: $branch_name"
    echo "    Configs created in configs/"
  fi

  echo ""
  echo "=== Done! sinarclient.tar.gz ready. ==="
  echo "When Pi is online: make sync HOST=<hostname>"
}

main "$@"
