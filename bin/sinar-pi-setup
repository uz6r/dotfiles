#!/usr/bin/env bash
#
# sinar-pi-setup - Super Pi Setup for Sinar Client
# Handles: New Pi setup, Modify existing Pi, Config creation, PR workflow
#
# Usage:
#   Interactive:   sinar-pi-setup
#   Non-interactive options:
#     --new <hostname> [--multi]        New Pi setup
#     --modify <hostname>              Modify existing Pi
#     --config <name> <tenant_id>      Create new config only
#     --rebuild                        Rebuild binaries only
#   Flags: --no-git --dry-run --skip-deploy
#

set -euo pipefail

RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
CYAN='\033[0;36m'
WHITE='\033[1;37m'
BOLD='\033[1m'
NC='\033[0m'
MAGENTA='\033[0;35m'

info()    { echo -e "${CYAN}[INFO]${NC}  $*"; }
success() { echo -e "${GREEN}[OK]${NC}    $*"; }
warn()    { echo -e "${YELLOW}[WARN]${NC}  $*"; }
error()   { echo -e "${RED}[ERR]${NC}   $*"; }

prompt() {
  local var_name="$1" prompt_text="$2" default="${3:-}"
  local input
  if [[ -n "$default" ]]; then
    read -rp "${prompt_text} [${default}]: " input
    eval "$var_name='${input:-$default}'"
  else
    read -rp "${prompt_text}: " input
    eval "$var_name='$input'"
  fi
}

prompt_secret() {
  local var_name="$1" prompt_text="$2"
  local input
  read -rsp "${prompt_text}: " input
  echo
  eval "$var_name='$input'"
}

if [[ -n "${SUDO_USER:-}" ]]; then
  ACTUAL_HOME="$(eval echo "~$SUDO_USER")"
else
  ACTUAL_HOME="$HOME"
fi
SINAR_DIR="${SINAR_DIR:-${COURTSITE_DIR:-$ACTUAL_HOME/Courtsite}/enjin/sinar-client}"
cd "$SINAR_DIR" || exit 1

MODE=""
PI_HOSTNAME=""
PI_PASS=""
TAILSACLE_AUTHKEY=""
IS_MULTI=0
SKIP_BUILD=false
SKIP_GIT=false
SKIP_DEPLOY=false
DRY_RUN=false
CREATE_PR=false

while [[ $# -gt 0 ]]; do
  case "$1" in
    --new)         MODE="new"; PI_HOSTNAME="$2"; shift 2 ;;
    --modify)      MODE="modify"; PI_HOSTNAME="$2"; shift 2 ;;
    --config)      MODE="config"; shift; break ;;
    --rebuild)     MODE="rebuild"; shift ;;
    --multi)       IS_MULTI=1; shift ;;
    --no-git)      SKIP_GIT=true; shift ;;
    --skip-deploy) SKIP_DEPLOY=true; shift ;;
    --dry-run)     DRY_RUN=true; shift ;;
    --pr)          CREATE_PR=true; shift ;;
    -h|--help)
      echo "Usage: sinar-pi-setup [OPTIONS]"
      echo ""
      echo "Modes:"
      echo "  --new <hostname>        Setup new Pi end-to-end"
      echo "  --modify <hostname>     Modify existing Pi (reconfigure/reinstall)"
      echo "  --config <name> <tid>  Create new config.toml only"
      echo "  --rebuild              Rebuild binaries only"
      echo ""
      echo "Options:"
      echo "  --multi                Multi-pi setup (2 boards)"
      echo "  --no-git               Skip git operations"
      echo "  --pr                   Create PR for config changes"
      echo "  --skip-deploy         Skip deploy to Pi"
      echo "  --dry-run              Show what would be done"
      exit 0
      ;;
    *) break ;;
  esac
done

ensure_sshpass() {
  if command -v sshpass &>/dev/null; then
    return
  fi
  warn "sshpass is required for automated SSH/rsync."
  local install
  read -rp "Install sshpass now? (y/n) [y]: " install
  if [[ "$install" =~ ^[Yy]$ ]]; then
    if command -v apt-get &>/dev/null; then
      sudo apt-get update && sudo apt-get install -y sshpass
    elif command -v brew &>/dev/null; then
      brew install hudochenkov/sshpass/sshpass
    else
      error "Cannot install sshpass. Install manually."
      exit 1
    fi
  fi
}

ssh_cmd() {
  local cmd="$1"
  local host="$PI_HOSTNAME"
  [[ "$host" != *.local ]] && host="$host.local"
  if command -v sshpass &>/dev/null && [[ -n "$PI_PASS" ]]; then
    SSHPASS="$PI_PASS" sshpass -e ssh -o StrictHostKeyChecking=no "pi@$host" "$cmd"
  else
    ssh -o StrictHostKeyChecking=no "pi@$host" "$cmd"
  fi
}

ssh_cmd_tty() {
  local cmd="$1"
  local host="$PI_HOSTNAME"
  [[ "$host" != *.local ]] && host="$host.local"
  if command -v sshpass &>/dev/null && [[ -n "$PI_PASS" ]]; then
    SSHPASS="$PI_PASS" sshpass -e ssh -o StrictHostKeyChecking=no -t "pi@$host" "$cmd"
  else
    ssh -o StrictHostKeyChecking=no -t "pi@$host" "$cmd"
  fi
}

rsync_to_pi() {
  local src="$1" dest="$2"
  local host="$PI_HOSTNAME"
  [[ "$host" != *.local ]] && host="$host.local"
  info "Rsyncing to Pi..."
  if command -v sshpass &>/dev/null && [[ -n "$PI_PASS" ]]; then
    SSHPASS="$PI_PASS" sshpass -e rsync -avz -e "ssh -o StrictHostKeyChecking=no" --protect-args "$src" "pi@$host:$dest"
  else
    rsync -avz -e "ssh -o StrictHostKeyChecking=no" --protect-args "$src" "pi@$host:$dest"
  fi
  success "Files synced."
}

do_build() {
  info "Building pi-client and sinar-client..."
  make
  success "Build complete."
}

create_config() {
  local centre_name="$1" tenant_id="$2" board_id="${3:-1}" toggle_time="${4:-5s}"
  local fallback_count="${5:-0}" frequency="${6:-10s}" brand="${7:-weiba}"
  
  centre_name="${centre_name%.toml}"
  local config_path="configs/${centre_name}.toml"
  local content="TenantID = \"${tenant_id}\"
BoardID = ${board_id}
FallbackCount = ${fallback_count}
Frequency = \"${frequency}\"
ToggleTime = \"${toggle_time}\"
Brand = \"${brand}\"
"
  if $DRY_RUN; then
    echo "  [DRY-RUN] write $config_path"
  else
    echo "$content" > "$config_path"
  fi
  echo "$config_path"
}

do_pkger() {
  local sinarcfg="$1" is_multi="$2"
  info "Packaging sinarclient.tar.gz..."
  if [[ "$is_multi" == "1" ]]; then
    make pkger-multi SINARCFG="$sinarcfg"
  else
    make pkger SINARCFG="$sinarcfg"
  fi
  success "Package created."
}

git_commit_and_pr() {
  local branch_name="$1" configs=("${@}")
  
  info "Committing config changes..."
  git add configs/
  git commit -m "Add pi configs for ${#configs[@]} setup(s)"
  
  if $CREATE_PR; then
    info "Pushing and creating PR..."
    git push -u origin "$branch_name"
    gh pr create --title "Sinar - Add Pi Config" --body "Generated by sinar-pi-setup"
  else
    info "Changes committed locally. Push manually with: git push"
  fi
}

rename_pi_hostname() {
  local new_hostname="$1"
  info "Renaming Pi hostname to '$new_hostname'..."
  
  ssh_cmd "echo '$new_hostname' | sudo tee /etc/hostname"
  ssh_cmd "sudo sed -i 's/127.0.1.1.*/127.0.1.1\t$new_hostname/' /etc/hosts"
  
  warn "Pi will reboot. Reconnect with: ssh pi@${new_hostname}.local"
  ssh_cmd "sudo reboot"
  
  info "Waiting for Pi to come back online..."
  sleep 30
}

deploy_to_pi() {
  info "Deploying to Pi '$PI_HOSTNAME'..."
  
  rsync_to_pi "sinarclient.tar.gz" "/home/pi/sinarclient/"
  
  ssh_cmd "mkdir -p /home/pi/sinarclient"
  ssh_cmd "cd /home/pi/sinarclient && tar -xzf sinarclient.tar.gz && rm sinarclient.tar.gz"
  ssh_cmd "cd /home/pi/sinarclient && chmod +x setup.sh"
  
  success "Files deployed."
}

run_setup_script() {
  info "Step 15: Modifying setup.sh to auto-answer..."
  ssh_cmd "sed -i 's/read -p.*Install vim.*/REPLY=n; echo n/' /home/pi/sinarclient/setup.sh"
  ssh_cmd "sed -i 's/read -p.*Install tailscale.*/REPLY=y; echo y/' /home/pi/sinarclient/setup.sh"
  
  info "Running modified setup.sh..."
  ssh_cmd_tty "cd /home/pi/sinarclient && sudo ./setup.sh"
  
  info "Waiting for setup to complete..."
  sleep 30
  
  info "Verifying Tailscale..."
  ssh_cmd "tailscale --version"
  
  success "Step 15: Setup complete"
}

connect_tailscale() {
  if [[ -z "$TAILSACLE_AUTHKEY" ]]; then
    prompt TAILSACLE_AUTHKEY "Tailscale authkey (from Bitwarden)"
  fi
  info "Waiting for Tailscale to install..."
  ssh_cmd "for i in 1 2 3 4 5; do command -v tailscale && break || sleep 3; done"
  if ! ssh_cmd "command -v tailscale" &>/dev/null; then
    info "Installing Tailscale..."
    ssh_cmd "curl -fsSL https://tailscale.com/install.sh | sh"
  fi
  info "Connecting Pi to Tailscale..."
  ssh_cmd "sudo tailscale up --authkey $TAILSACLE_AUTHKEY"
  success "Tailscale connected."
}

verify_sinarclient() {
  info "Step 17: Verifying sinarclient..."
  ssh_cmd "systemctl status sinarclient --no-pager 2>&1 || systemctl status sinarclient1 --no-pager 2>&1 || echo 'Done'" || true
  success "Step 17 complete."
  echo ""
  echo "========================================"
  echo "ALL AUTOMATED STEPS COMPLETE (10-17)"
  echo "========================================"
}

get_pi_info() {
  info "Getting Pi info..."
  
  local ts_ip pi_hostname os_ver net_tool
  ts_ip=$(ssh_cmd "tailscale ip -4 2>/dev/null || echo ''" 2>/dev/null || true)
  pi_hostname=$(ssh_cmd "hostname" 2>/dev/null || echo "$PI_HOSTNAME")
  local ver_id
  ver_id=$(ssh_cmd "grep VERSION_ID /etc/os-release | cut -d'\"' -f2" 2>/dev/null || echo "")
  [[ -n "$ver_id" ]] && os_ver="Debian $ver_id" || os_ver="Debian"
  net_tool=$(ssh_cmd "command -v nmcli && echo 'NetworkManager' || echo 'dhcpcd'" 2>/dev/null || echo "unknown")
  
  local setup_type
  [[ "$IS_MULTI" = "1" ]] && setup_type="multi" || setup_type="single"
  
  echo ""
  echo -e "${MAGENTA}╭───────────────────────────────────────────────────╮${NC}"
  echo -e "${MAGENTA}│${NC}        ${BOLD}Pi Info (for Step 19 & 20)${NC}                 ${MAGENTA}│${NC}"
  echo -e "${MAGENTA}╰───────────────────────────────────────────────────╯${NC}"
  echo ""
  echo "=== For Uptime Kuma (Step 19) ==="
  echo "  Friendly Name: $pi_hostname"
  echo "  Hostname: $ts_ip"
  echo ""
  echo "=== For Pi Info Table (Step 20) ==="
  echo "  hostname: $pi_hostname"
  echo "  ip_address: $ts_ip"
  echo "  networking_tool: $net_tool"
  echo "  os_version: $os_ver"
  echo "  sinarclient_setup: $setup_type"
  echo ""
}

print_manual_steps() {
  local ts_ip="" pi_hostname="" os_ver="" net_tool=""
  if [[ -n "$PI_HOSTNAME" ]]; then
    ts_ip=$(ssh_cmd "tailscale ip -4 2>/dev/null || echo ''" 2>/dev/null || true)
    pi_hostname=$(ssh_cmd "hostname" 2>/dev/null || echo "$PI_HOSTNAME")
local ver_id
ver_id=$(ssh_cmd "grep VERSION_ID /etc/os-release | cut -d'\"' -f2" 2>/dev/null || echo "")
[[ -n "$ver_id" ]] && os_ver="Debian $ver_id" || os_ver="Debian"
net_tool=$(ssh_cmd "command -v nmcli && echo 'NetworkManager' || echo 'dhcpcd'" 2>/dev/null || echo "unknown")
  fi
  
  local setup_type
  [[ "$IS_MULTI" = "1" ]] && setup_type="multi" || setup_type="single"
  
  echo ""
  echo -e "${MAGENTA}╭───────────────────────────────────────────────────╮${NC}"
  echo -e "${MAGENTA}│${NC}   ${BOLD}AUTOMATED (handled by script): Steps 10-17${NC}        ${MAGENTA}│${NC}"
  echo -e "${MAGENTA}╰───────────────────────────────────────────────────╯${NC}"
  echo "  10) Build Sinar-Client"
  echo "  11) Generate .toml config"
  echo "  12) Package config"
  echo "  13) Check Pi online"
  echo "  14) Sync files to Pi"
  echo "  15) Unpack & run setup.sh"
  echo "  16) Connect Tailscale"
  echo "  17) Verify sinarclient running"
  echo ""
  echo -e "${MAGENTA}╭───────────────────────────────────────────────────╮${NC}"
  echo -e "${MAGENTA}│${NC}   ${BOLD}REMAINING MANUAL STEPS (18-21)${NC}                ${MAGENTA}│${NC}"
  echo -e "${MAGENTA}╰───────────────────────────────────────────────────╯${NC}"
  echo ""
  echo -e "${YELLOW}Step 18: Test Automation from Business Konsol${NC}"
  echo "  → Go to https://business.courtsite.my"
  echo "  → Find your centre and go to Lighting Tab"
  echo "  → Toggle lights ON then OFF"
  echo "  → Verify relay clicks (you should hear it)"
  echo ""
  echo -e "${YELLOW}Step 19: Add to Uptime Kuma${NC}"
  echo "  → URL: http://100.93.194.155:3001/dashboard"
  echo "  → Monitor Type: Ping"
  if [[ -n "$pi_hostname" ]]; then
    echo "  → Friendly Name: $pi_hostname"
  fi
  if [[ -n "$ts_ip" ]]; then
    echo "  → Hostname (Tailscale IP): $ts_ip"
  else
    echo "  → Hostname: <Pi's Tailscale IP>"
  fi
  echo ""
  echo -e "${YELLOW}Step 20: Add to Pi Info Table${NC}"
  echo "  → Excel: Pi Info Table.xlsx"
  if [[ -n "$pi_hostname" ]]; then
    echo "  → hostname: $pi_hostname"
  fi
  if [[ -n "$ts_ip" ]]; then
    echo "  → ip_address: $ts_ip"
  else
    echo "  → ip_address: <tailscale ip -4>"
  fi
  if [[ -n "$net_tool" ]]; then
    echo "  → networking_tool: $net_tool"
  else
    echo "  → networking_tool: <nmcli/other>"
  fi
  if [[ -n "$os_ver" ]]; then
    echo "  → os_version: $os_ver"
  else
    echo "  → os_version: <cat /etc/os-release>"
  fi
  echo "  → sinarclient_setup: $setup_type"
  echo ""
  echo -e "${YELLOW}Step 21: Add to Infra Repo${NC}"
  echo "  → Use gather_pi Ansible Playbook"
  echo ""
  echo -e "${MAGENTA}╰───────────────────────────────────────────────────╯${NC}"
}

interactive_menu() {
  echo ""
  echo -e "${MAGENTA}╭───────────────────────────────────────────────────╮${NC}"
  echo -e "${MAGENTA}│${NC}           ${BOLD}SINAR PI SETUP${NC}                         ${MAGENTA}│${NC}"
  echo -e "${MAGENTA}╰───────────────────────────────────────────────────╯${NC}"
  echo ""
  echo -e "${WHITE}What would you like to do?${NC}"
  echo ""
  echo -e "${WHITE}  1)${NC}  New Pi Setup         - Build, package, deploy to new Pi"
  echo -e "${WHITE}  2)${NC}  Modify Existing Pi  - Reconfigure/reinstall on existing Pi"
  echo -e "${WHITE}  3)${NC}  Create Config Only - Create new .toml config file"
  echo -e "${WHITE}  4)${NC}  Rebuild Only        - Just build binaries"
  echo -e "${WHITE}  5)${NC}  Get Pi Info         - Show info for Uptime Kuma / Pi Table"
  echo -e "${WHITE}  6)${NC}  Exit"
  echo ""
  
  local choice
  prompt choice "Select option (1-6)" "1"
  
  case "$choice" in
    1) MODE="new" ;;
    2) MODE="modify" ;;
    3) MODE="config" ;;
    4) MODE="rebuild" ;;
    5) MODE="info" ;;
    6) info "Exiting."; exit 0 ;;
    *) error "Invalid option."; exit 1 ;;
  esac
}

handle_new_pi() {
  if [[ -z "$PI_HOSTNAME" ]]; then
    prompt PI_HOSTNAME "Pi hostname (e.g. oncidiumhallkotakemuning)"
  fi
  
  if [[ -z "$PI_PASS" ]]; then
    prompt_secret PI_PASS "Pi SSH password"
  fi
  
  ensure_sshpass
  
  local pr_choice
  echo "Create PR? (1) No  (2) Yes"
  prompt pr_choice "Choice" "1"
  [[ "$pr_choice" == "2" ]] && CREATE_PR=true
  
  local IS_MULTI=0
  echo "Package: (1) single  (2) multi"
  local pkg_choice
  prompt pkg_choice "Choice" "1"
  [[ "$pkg_choice" == "2" ]] && IS_MULTI=1
  
  local centre_name tenant_id board_id toggle_time
  prompt centre_name "Centre name (e.g. OncidiumHallKotaKemuning)"
  prompt tenant_id "Tenant ID (from Metabase)"
  prompt board_id "BoardID" "1"
  prompt toggle_time "ToggleTime (e.g. 5s)" "5s"
  
  local fallback_count="0" frequency="10s" brand="weiba"
  local config_path
  config_path=$(create_config "$centre_name" "$tenant_id" "$board_id" "$toggle_time" "$fallback_count" "$frequency" "$brand")
  success "Config created: $config_path"
  
  if $CREATE_PR; then
    local branch_name="pi-setup-${centre_name}-$(date +%Y%m%d)"
    info "Creating branch: $branch_name"
    git checkout master 2>/dev/null || true
    git pull origin master
    git checkout -b "$branch_name"
    git add configs/
    git commit -m "Add config for $centre_name"
  fi
  
  $SKIP_BUILD || do_build
  do_pkger "$config_path" "$IS_MULTI"
  
  if [[ "$SKIP_DEPLOY" == "false" ]]; then
    trap 'rm -f "$config_path"; error "Deployment failed, config discarded."' EXIT
    deploy_to_pi
    success "Step 14-15: Files deployed & setup.sh run"
    run_setup_script
    
    echo ""
    echo "Step 16: Tailscale authkey required (from Bitwarden)"
    echo "  Example: tskey-auth-kXxXxXxXxXxXxXxXxX..."
    while [[ -z "$TAILSACLE_AUTHKEY" ]]; do
      prompt_secret TAILSACLE_AUTHKEY "Tailscale authkey (REQUIRED)"
    done
    connect_tailscale
    
    verify_sinarclient
    success "Step 17: Verification complete"
    trap - EXIT
  fi
  
  echo ""
  success "========================================"
  success "ALL STEPS COMPLETE (10-17)"
  success "========================================"
  print_manual_steps
}

handle_modify_pi() {
  if [[ -z "$PI_HOSTNAME" ]]; then
    prompt PI_HOSTNAME "Pi hostname to modify"
  fi
  
  if [[ -z "$PI_PASS" ]]; then
    prompt_secret PI_PASS "Pi SSH password"
  fi
  
  ensure_sshpass
  
  local pr_choice
  echo ""
  echo "Create PR for config? (1) No  (2) Yes"
  prompt pr_choice "Choice" "1"
  [[ "$pr_choice" == "2" ]] && CREATE_PR=true
  
  echo ""
  echo "What to modify?"
  echo "  1) Fresh reinstall (like new Pi, clean SD)"
  echo "  2) New config for this Pi"
  echo "  3) Rename Pi hostname"
  echo "  4) Reconnect Tailscale"
  echo "  5) Get Info for Uptime Kuma / Pi Table"
  echo "  6) Check/Verify (status, logs)"
  echo ""
  local mod_choice
  prompt mod_choice "Choice" "1"
  
  if [[ "$mod_choice" == "5" ]]; then
    get_pi_info
    return 0
  fi
  
  if [[ "$mod_choice" == "6" ]]; then
    echo "What to check/verify?"
    echo "  1) Check sinarclient status"
    echo "  2) Check Tailscale status"
    echo "  3) View client logs"
    echo ""
    local check_choice
    prompt check_choice "Choice" "1"
    
    case "$check_choice" in
      1)
        ssh_cmd "sudo systemctl status sinarclient"
        ;;
      2)
        ssh_cmd "tailscale status"
        ;;
      3)
        ssh_cmd "sudo journalctl -u sinarclient -n 50 --no-pager"
        ;;
    esac
    return 0
  fi
  
  case "$mod_choice" in
    1)
      info "Fresh reinstall (clean SD)..."
      local centre_name tenant_id board_id toggle_time
      prompt centre_name "Centre name (e.g. OncidiumHallKotaKemuning)"
      prompt tenant_id "Tenant ID (from Metabase)"
      prompt board_id "BoardID" "1"
      prompt toggle_time "ToggleTime (e.g. 5s)" "5s"
      
      local fallback_count="0" frequency="10s" brand="weiba"
      local config_path
      config_path=$(create_config "$centre_name" "$tenant_id" "$board_id" "$toggle_time" "$fallback_count" "$frequency" "$brand")
      
      if $CREATE_PR; then
        info "Creating PR for config..."
        local branch_name="pi-setup-${centre_name}-$(date +%Y%m%d)"
        git checkout master 2>/dev/null || true
        git pull origin master
        git checkout -b "$branch_name"
        git add "configs/${centre_name}"*.toml 2>/dev/null || true
        git commit -m "Update config for $centre_name" 2>/dev/null || true
      fi
      
      $SKIP_BUILD || do_build
      do_pkger "$config_path" "0"
      deploy_to_pi
      run_setup_script
      
      echo ""
      echo "Step 16: Tailscale authkey required (from Bitwarden)"
      echo "  Example: tskey-auth-kXxXxXxXxXxXxXxXxX..."
      while [[ -z "$TAILSACLE_AUTHKEY" ]]; do
        prompt_secret TAILSACLE_AUTHKEY "Tailscale authkey (REQUIRED)"
      done
      connect_tailscale
      
      verify_sinarclient
      ;;
    2)
      info "Fetching current config from Pi..."
      local cur_centre cur_tenant cur_board cur_toggle
      cur_centre=$(ssh_cmd "grep '^CentreName' /home/pi/sinarclient/centre.toml | cut -d'\"' -f2")
      cur_tenant=$(ssh_cmd "grep '^TenantID' /home/pi/sinarclient/centre.toml | cut -d'\"' -f2")
      cur_board=$(ssh_cmd "grep '^BoardID' /home/pi/sinarclient/centre.toml | cut -d'=' -f2 | tr -d ' '")
      cur_toggle=$(ssh_cmd "grep '^ToggleTime' /home/pi/sinarclient/centre.toml | cut -d'\"' -f2")
      
      local centre_name tenant_id board_id toggle_time
      prompt centre_name "Centre name (leave empty to keep: $cur_centre)" "$cur_centre"
      prompt tenant_id "Tenant ID (leave empty to keep: $cur_tenant)" "$cur_tenant"
      prompt board_id "BoardID (leave empty to keep: $cur_board)" "$cur_board"
      prompt toggle_time "ToggleTime (leave empty to keep: $cur_toggle)" "$cur_toggle"
      
      [[ -z "$centre_name" ]] && centre_name="$cur_centre"
      [[ -z "$tenant_id" ]] && tenant_id="$cur_tenant"
      [[ -z "$board_id" ]] && board_id="$cur_board"
      [[ -z "$toggle_time" ]] && toggle_time="$cur_toggle"
      
      local fallback_count="0" frequency="10s" brand="weiba"
      local config_path
      config_path=$(create_config "$centre_name" "$tenant_id" "$board_id" "$toggle_time" "$fallback_count" "$frequency" "$brand")
      
      if $CREATE_PR; then
        info "Creating PR for config..."
        local branch_name="pi-setup-${centre_name}-$(date +%Y%m%d)"
        git checkout master 2>/dev/null || true
        git pull origin master
        git checkout -b "$branch_name"
        git add "configs/${centre_name}"*.toml 2>/dev/null || true
        git commit -m "Update config for $centre_name" 2>/dev/null || true
      fi
      
      do_pkger "$config_path" "0"
      deploy_to_pi
      run_setup_script
      
      echo ""
      echo "Step 16: Tailscale authkey required (from Bitwarden)"
      echo "  Example: tskey-auth-kXxXxXxXxXxXxXxXxX..."
      while [[ -z "$TAILSACLE_AUTHKEY" ]]; do
        prompt_secret TAILSACLE_AUTHKEY "Tailscale authkey (REQUIRED)"
      done
      connect_tailscale
      
      verify_sinarclient
      echo ""
      success "========================================"
      success "ALL STEPS COMPLETE"
      success "========================================"
      print_manual_steps
      ;;
    3)
      local new_hostname
      prompt new_hostname "New hostname"
      rename_pi_hostname "$new_hostname"
      PI_HOSTNAME="$new_hostname"
;;
    4)
      if [[ -z "$TAILSACLE_AUTHKEY" ]]; then
        prompt TAILSACLE_AUTHKEY "Tailscale authkey"
      fi
      connect_tailscale
      ;;
  esac
  
  echo ""
  success "========================================"
  success "ALL STEPS COMPLETE"
  success "========================================"
  print_manual_steps
}

handle_config_only() {
  if [[ $# -ge 2 ]]; then
    local centre_name="$1" tenant_id="$2"
  else
    local centre_name tenant_id
    prompt centre_name "Centre name (e.g. OncidiumHallKotaKemuning)"
    prompt tenant_id "Tenant ID (from Metabase)"
  fi
  
  local board_id toggle_time
  prompt board_id "BoardID" "1"
  prompt toggle_time "ToggleTime (e.g. 5s)" "5s"
  
  local fallback_count="0" frequency="10s" brand="weiba"
  local config_path
  config_path=$(create_config "$centre_name" "$tenant_id" "$board_id" "$toggle_time" "$fallback_count" "$frequency" "$brand")
  success "Config created: $config_path"
  
  if $CREATE_PR; then
    local branch_name="pi-setup-${centre_name}-$(date +%Y%m%d)"
    git checkout master 2>/dev/null || true
    git pull origin master
    git checkout -b "$branch_name"
    git add configs/
    git commit -m "Add config for $centre_name"
    git push -u origin "$branch_name"
    gh pr create --title "Sinar - Add ${centre_name} Config" --body "Generated by sinar-pi-setup"
    success "PR created!"
  else
    warn "Config created but not committed. Use --pr to create PR."
  fi
}

handle_rebuild() {
  info "Rebuilding binaries..."
  cd "$SINAR_DIR" || exit 1
  do_build
  success "Build complete."
}

handle_get_info() {
  if [[ -z "$PI_HOSTNAME" ]]; then
    prompt PI_HOSTNAME "Pi hostname"
  fi
  
  if [[ -z "$PI_PASS" ]]; then
    prompt_secret PI_PASS "Pi SSH password"
  fi
  
  ensure_sshpass
  get_pi_info
}

main() {
  if [[ -z "$MODE" ]]; then
    interactive_menu
  fi
  
  case "$MODE" in
    new)       handle_new_pi "$@" ;;
    modify)    handle_modify_pi ;;
    config)    handle_config_only "$@" ;;
    rebuild)   handle_rebuild ;;
    info)     handle_get_info ;;
    *)        error "Unknown mode: $MODE"; exit 1 ;;
  esac
}

main "$@"